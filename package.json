{
  "name": "xalt-factcheck",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Live fact-checking pipeline for video streams with producer dashboard and overlay graphics",
  "scripts": {
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:client": "vite build",
    "start": "node dist/server.js",
    "dev": "tsx --watch src/server.ts",
    "dev:client": "vite dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.2",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "satori": "^0.25.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0",
    "vue": "^3.5.30"
  },
  "engines": {
    "node": ">=20"
  }
}
